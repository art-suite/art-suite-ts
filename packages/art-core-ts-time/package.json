{
  "name": "@art-suite/art-core-ts-time",
  "version": "0.4.0",
  "description": "A TypeScript string utility library",
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/art-suite/art-suite-ts"
  },
  "license": "MIT",
  "author": "Shane Delamore",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "npm run clean",
    "build": "npx sort-package-json;tsdown src/index.ts --format esm,cjs --dts --sourcemap",
    "build:clean": "npm run clean && npm run build",
    "check:types": "tsc --noEmit",
    "check:types:fast": "tsc --noEmit --incremental",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@art-suite/art-core-ts-comprehensions": "^0.5.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0"
  }
}
